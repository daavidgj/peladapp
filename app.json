{
  "expo": {
    "name": "peladapp",
    "slug": "peladapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/peladaapplogo.png",
    "scheme": "peladapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Favicon logo peladapp.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0A7725"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.peladapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Favicon logo peladapp.jpg",
        "backgroundColor": "#0A7725"
      },
      "versionCode": 9,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.peladapp",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Favicon logo peladapp.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "42b96a72-8658-47c3-9cfc-a729b8a65a7f"
      }
    }
  }
}